# Email (SMTP) - replace with your provider credentials
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=emailbot@gmail.com
EMAIL_HOST_PASSWORD=replace_with_app_password
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=emailbot@gmail.com

# Django
DJANGO_SECRET_KEY=replace_with_a_long_random_secret
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=yourdomain.com,localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://*.ngrok-free.app,https://*.ngrok.app
DJANGO_USE_X_FORWARDED_HOST=true

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=replace_with_google_client_id
GOOGLE_OAUTH_CLIENT_SECRET=replace_with_google_client_secret

# Security overrides (optional)
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true
SECURE_SSL_REDIRECT=true
SECURE_HSTS_SECONDS=63072000
SECURE_HSTS_INCLUDE_SUBDOMAINS=true
SECURE_HSTS_PRELOAD=true
X_FRAME_OPTIONS=DENY

# Qdrant (optional, for semantic search)
# Local Docker example:
# QDRANT_URL=YOUR_QDRANT_URL
# QDRANT_API_KEY=
# Cloud Qdrant example:
# QDRANT_URL=https://<your-cloud-qdrant-endpoint>
# QDRANT_API_KEY=<your-cloud-api-key>
QDRANT_URL=YOUR_QDRANT_URL
QDRANT_API_KEY=
QDRANT_COLLECTION=skillforge_support_kb
QDRANT_EMBEDDING_MODEL=intfloat/multilingual-e5-small
QDRANT_PREFER_GRPC=false
# Set to false if remote/cloud endpoint cannot be version-checked
QDRANT_CHECK_COMPATIBILITY=true

# Botcahx AI API (primary for RAG support chat)
BOTCAHX_API_URL=https://yourbot.com
BOTCAHX_API_KEY=replace_with_botcahx_api_key
BOTCAHX_TIMEOUT_SECONDS=120

# Gemini API fallback (optional)
GEMINI_API_KEY=replace_with_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_API_URL=https://yourAPIURL.com
GEMINI_TEMPERATURE=0.9
GEMINI_TOP_P=0.95
GEMINI_TOP_K=64
GEMINI_MAX_OUTPUT_TOKENS=256
GEMINI_TIMEOUT_SECONDS=60

# Support RAG Feature (set to true to enable support chat with RAG)
SUPPORT_RAG_ENABLED=true

# Midtrans Payment Gateway (optional)
MIDTRANS_NOTIFICATION_URL=https://yourdomain.com/courses/payment/midtrans/notification/
MIDTRANS_SERVER_KEY=replace_with_midtrans_server_key
MIDTRANS_CLIENT_KEY=replace_with_midtrans_client_key